// Schéma de la base de données chatpitre.
// Prisma 7 : l'URL de connexion vit dans prisma.config.ts, pas dans ce fichier.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Utilisateurs
// ---------------------------------------------------------------------------

/// Propriétaire de chat OU admin. Le statut admin est déterminé par l'email
/// (présence dans la variable d'environnement ADMIN_EMAILS), pas par un champ.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  address      String?
  postalCode   String?
  city         String?
  adminNotes   String? // note interne de la maison sur ce client (jamais visible du client)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cats          Cat[]
  bookings      Booking[]
  notifications Notification[]
  messages      BookingMessage[] // messages écrits par cet utilisateur
  stayUpdates   StayUpdate[] // entrées du carnet de séjour postées (admin)

  appointments        Appointment[] @relation("AppointmentClient") // rdv où l'utilisateur est le client
  appointmentsCreated Appointment[] @relation("AppointmentCreatedBy") // rdv planifiés (admin)

  uploadedDocuments CatDocument[] // documents téléversés par cet utilisateur
}

// ---------------------------------------------------------------------------
// Chats
// ---------------------------------------------------------------------------

enum CatSex {
  MALE
  FEMALE
}

/// Fiche d'un chat rattaché à un propriétaire (User).
model Cat {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  birthDate   DateTime?
  sex         CatSex
  breed       String?
  color       String?
  weight      Float? // poids en kg — grandeur physique, pas un montant
  photoUrl    String?
  personality String? // texte libre

  // Critères d'admission
  isSterilized     Boolean @default(false)
  isIdentified     Boolean @default(false) // puce ou tatouage
  vaccinesUpToDate Boolean @default(false)
  isSociable       Boolean @default(false)

  // Vétérinaire
  vetName    String?
  vetClinic  String?
  vetPhone   String?
  vetAddress String?

  // Informations médicales
  allergies         String?
  currentTreatments String?
  medicalNotes      String?
  specialDiet       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingCats BookingCat[]
  stayUpdates StayUpdate[]
  documents   CatDocument[]

  @@index([ownerId])
}

// ---------------------------------------------------------------------------
// Documents des chats (pièces téléversées)
// ---------------------------------------------------------------------------

enum DocumentType {
  VACCINATION // carnet de vaccination
  IDENTIFICATION // puce / I-CAD
  HEALTH_CERTIFICATE // certificat de santé vétérinaire
  ANTIPARASITIC // antiparasitaire (puces, vermifuge)
  PRESCRIPTION // ordonnance / traitement
  PASSPORT // passeport européen / antirabique
  STERILIZATION // certificat de stérilisation
  INSURANCE // assurance santé animale
  CARE_AUTHORIZATION // autorisation de soins
  DIET // régime & consignes
  PHOTO // photo
  OTHER // autre (libellé libre)
}

/// Document associé à un chat (carnet de vaccination, certificat de santé…).
/// Le fichier est stocké sur disque sous un nom OPAQUE (storageKey) et n'est
/// servi que par une route authentifiée — jamais d'URL publique. Le nom
/// d'affichage « à notre sauce » est calculé au téléchargement.
model CatDocument {
  id String @id @default(cuid())

  catId String
  cat   Cat    @relation(fields: [catId], references: [id], onDelete: Cascade)

  // Auteur de l'envoi (client ou admin). SET NULL si le compte disparaît.
  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  type         DocumentType
  customLabel  String? // rempli uniquement pour type = OTHER
  originalName String // nom du fichier d'origine (conservé pour info)
  storageKey   String       @unique // nom opaque sur disque (pas devinable, pas de collision)
  mimeType     String
  sizeBytes    Int
  documentDate DateTime? // date du document (ex. vaccination) ; sinon createdAt

  createdAt DateTime @default(now())

  @@index([catId])
  @@index([catId, type])
}

// ---------------------------------------------------------------------------
// Réservations
// ---------------------------------------------------------------------------

enum BookingStatus {
  PENDING // demande envoyée, en attente côté admin
  QUESTION_ASKED // l'admin a posé une question, attend la réponse du client
  ACCEPTED // réservation validée
  REJECTED // réservation refusée
  CANCELLED // réservation annulée par le client ou l'admin
  COMPLETED // séjour terminé
}

/// Base de facturation d'un supplément. Le total de ligne se déduit du prix
/// unitaire et d'un multiplicateur dépendant de l'unité :
///   PER_DAY   → × nombre de nuits du séjour (auto)
///   PER_VISIT → × quantité saisie (nb de visites / d'unités)
///   FLAT      → forfait, montant unique pour le séjour (× 1)
enum ExtraUnit {
  PER_DAY
  PER_VISIT
  FLAT
}

/// Demande de réservation d'un séjour pour un ou plusieurs chats.
model Booking {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)

  clientNotes String? // notes du client à la demande
  adminNotes  String? // notes internes de l'admin

  // Tarification posée par l'admin au moment du devis (passage à ACCEPTED).
  // Reste null tant que la demande est PENDING / QUESTION_ASKED.
  pricePerFirstCat  Decimal? @db.Decimal(10, 2)
  pricePerExtraCat  Decimal? @db.Decimal(10, 2)
  depositPercentage Int      @default(20)
  totalAmount       Decimal? @db.Decimal(10, 2) // nuitées × (1er chat + extras) + suppléments
  depositAmount     Decimal? @db.Decimal(10, 2) // depositPercentage % du total

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cats         BookingCat[]
  extras       BookingExtra[]
  messages     BookingMessage[]
  invoices     Invoice[]
  stayUpdates  StayUpdate[]
  appointments Appointment[]

  @@index([userId])
  @@index([status])
}

/// Avis de l'admin sur un chat pour un séjour donné.
///   PENDING  → pas encore évalué
///   OK       → validé, rien à signaler
///   RESERVE  → validé avec réserve (ex. « non stérilisé mais à jour vaccins »)
///   REJECTED → refusé pour ce chat
enum CatReviewStatus {
  PENDING
  OK
  RESERVE
  REJECTED
}

/// Table de liaison Booking <-> Cat (une réservation concerne 1+ chats).
model BookingCat {
  bookingId String
  catId     String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cat       Cat     @relation(fields: [catId], references: [id])

  // Avis de l'admin sur ce chat pour ce séjour, visible aussi du client.
  reviewStatus CatReviewStatus @default(PENDING)
  reviewNote   String?

  @@id([bookingId, catId])
  @@index([catId])
}

/// Ligne de supplément d'un devis (nourriture spéciale, brossage, soins,
/// visite véto…). Snapshot : `label` et `amount` sont figés au moment où la
/// ligne est posée, indépendamment du catalogue.
///
/// Deux origines possibles :
/// — admin : ligne chiffrée par la maison (`requestedByClient = false`).
/// — client : option demandée à la réservation (`requestedByClient = true`).
///   Le prix est alors indicatif (issu du catalogue) ou `null` (« à chiffrer »
///   pour une demande libre) ; l'admin confirme le montant dans le devis.
model BookingExtra {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  label             String
  // Base de facturation (snapshot). Le total `amount` est dérivé serveur de
  // `unitAmount` × multiplicateur (nuits / quantity / 1 selon `unit`).
  unit              ExtraUnit @default(FLAT)
  // Prix unitaire (par jour / par visite / forfait). `null` = pas encore
  // chiffré (demande client libre) — l'admin le pose dans le devis.
  unitAmount        Decimal?  @db.Decimal(10, 2)
  // Nombre d'unités (visites). Ignoré pour PER_DAY (utilise les nuits) et
  // vaut 1 pour FLAT.
  quantity          Int       @default(1)
  // Total de ligne calculé (snapshot). `null` = montant non encore chiffré.
  // `0` est un prix valide (ex. « croquettes fournies par le client »).
  amount            Decimal?  @db.Decimal(10, 2)
  // Origine de la ligne : demandée par le client à la réservation, ou posée
  // par l'admin. Sert à l'affichage (indicatif vs confirmé) et au devis.
  requestedByClient Boolean   @default(false)
  sortOrder         Int       @default(0)

  createdAt DateTime @default(now())

  @@index([bookingId])
}

/// Préset du catalogue de suppléments — édité côté admin. Sert à pré-remplir
/// les lignes BookingExtra dans le formulaire de devis. Une modification du
/// préset n'altère pas les devis déjà posés.
model ExtraPreset {
  id            String    @id @default(cuid())
  label         String
  // Base de facturation par défaut du supplément ; `defaultAmount` est le
  // prix unitaire correspondant (par jour / par visite / forfait).
  unit          ExtraUnit @default(FLAT)
  defaultAmount Decimal   @db.Decimal(10, 2)
  sortOrder     Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Message du fil de discussion d'une réservation.
model BookingMessage {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  isFromAdmin Boolean   @default(false)
  content     String
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([authorId])
}

// ---------------------------------------------------------------------------
// Carnet de séjour
// ---------------------------------------------------------------------------

enum StayUpdateImageVariant {
  COBALT
  PAPRIKA
  CANARI
  FEUILLE
}

enum StayUpdateImagePose {
  SITTING
  SLEEPING
  STANDING
  WATCHING
}

/// Entrée du carnet de séjour : la maison poste une note photo par jour
/// pour chaque pensionnaire en séjour. Le client la voit sur la page
/// détail de sa réservation. Tant que l'upload réel n'est pas en place,
/// `imageVariant` + `imagePose` désignent l'illustration Charley Harper
/// utilisée à la place de la photo.
model StayUpdate {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  catId String
  cat   Cat    @relation(fields: [catId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  imageUrl     String? // futur upload réel
  imageVariant StayUpdateImageVariant @default(COBALT)
  imagePose    StayUpdateImagePose    @default(SITTING)
  content      String

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([catId])
}

// ---------------------------------------------------------------------------
// Rendez-vous (visioconférence)
// ---------------------------------------------------------------------------

enum AppointmentStatus {
  SCHEDULED // créneau posé, à venir
  COMPLETED // appel effectué
  CANCELLED // rendez-vous annulé
}

/// Télé-rendez-vous : appel vidéo 1:1 entre un client (propriétaire) et la
/// maison (admin). La vidéo passe en WebRTC pair-à-pair ; cette table ne porte
/// que la métadonnée du rdv (créneau, statut, lien au séjour), jamais l'état
/// SDP/ICE volatile du signaling (qui vit dans un bus en mémoire). L'accès à la
/// salle est gardé par session : seuls le client concerné et un admin entrent.
model Appointment {
  id String @id @default(cuid())

  // Client concerné (propriétaire). Calqué sur Booking.userId : Restrict.
  clientId String
  client   User   @relation("AppointmentClient", fields: [clientId], references: [id], onDelete: Restrict)

  // Séjour rattaché — optionnel (un appel-conseil peut précéder toute
  // réservation) ; SetNull pour préserver l'historique si le séjour est supprimé.
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Auteur de la planification (généralement l'admin). SetNull si le compte part.
  createdById String?
  createdBy   User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  scheduledAt DateTime // début du créneau
  durationMin Int               @default(30)
  status      AppointmentStatus @default(SCHEDULED)
  title       String? // motif du rendez-vous (texte libre)
  notes       String? // notes internes de l'admin

  // Fenêtre réelle de l'appel (renseignée au connect / hangup).
  startedAt DateTime?
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([bookingId])
  @@index([scheduledAt])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

enum NotificationType {
  BOOKING_REQUESTED // (admin) nouvelle demande de réservation
  BOOKING_ACCEPTED // (client) réservation acceptée
  BOOKING_REJECTED // (client) réservation refusée
  BOOKING_QUESTION // (client) l'admin a posé une question
  MESSAGE_RECEIVED // (bidirectionnel) nouveau message reçu
  CAT_REVIEWED // (client) la maison a posé un avis sur un chat
  ARRIVAL_REMINDER // (admin) arrivée prévue le lendemain
  APPOINTMENT_SCHEDULED // (client) un télé-rendez-vous a été planifié
  APPOINTMENT_CANCELLED // (client) un télé-rendez-vous a été annulé
}

/// Notification in-app destinée à un utilisateur.
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   NotificationType
  title  String
  body   String?
  link   String? // URL relative à ouvrir au clic
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Facturation
// ---------------------------------------------------------------------------

enum InvoiceType {
  DEPOSIT // facture d'acompte
  BALANCE // facture de solde
  FULL // facture complète (si pas d'acompte)
}

/// Facture rattachée à une réservation.
model Invoice {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  number    String      @unique // numérotation continue, ex. : 2026-0001
  type      InvoiceType
  amountHT  Decimal     @db.Decimal(10, 2)
  vatRate   Decimal     @default(0) @db.Decimal(5, 2) // taux de TVA en %
  amountTTC Decimal     @db.Decimal(10, 2)

  issuedAt      DateTime  @default(now())
  paidAt        DateTime?
  paymentMethod String? // "CASH", "TRANSFER", "CARD", etc.
  pdfPath       String? // chemin du PDF stocké

  @@index([bookingId])
}

// ---------------------------------------------------------------------------
// Réglages
// ---------------------------------------------------------------------------

/// Réglages configurables côté admin (tarifs, etc.) sans redéploiement.
model Setting {
  key   String @id
  value String
}
