# ---------------------------------------------------------------------------
# chatpitre — variables d'environnement (exemple)
# Copier ce fichier en .env et renseigner les valeurs.
# ---------------------------------------------------------------------------

# Base de données PostgreSQL.
# En dev : le service Postgres du docker-compose.yml.
DATABASE_URL=postgresql://chatpitre:chatpitre@localhost:5432/chatpitre

# Secret de signature des sessions (HMAC-SHA256), 32 caractères minimum.
# Générer avec : openssl rand -hex 32
AUTH_SECRET=remplacer-par-le-resultat-de-openssl-rand-hex-32

# Emails des administrateurs, séparés par des virgules (insensible à la casse).
# Tout compte dont l'email est listé ici dispose des droits admin.
ADMIN_EMAILS=admin@chatpitre.local

# URL de base de l'application.
BASE_URL=http://localhost:3000

# Environnement : development | production
NODE_ENV=development
